.env
.env.local
.env.*.local

# Key files
*.pem
*.key
*.p12
*.jks
*.keystore
*.truststore

# OAuth2 secrets (if stored in files)
oauth2-secrets/
client-secrets/
jwt-keys/

# SSL certificates
*.crt
*.cert
*.ca-bundle

