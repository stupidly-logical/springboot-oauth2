node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# =============================================================================
# Configuration Files (Environment Specific)
# =============================================================================
# Local development configurations
application-local.properties
# application-dev.properties is tracked — contains only logging config, no secrets
application-development.properties
application-test.properties

# Production configurations (should be managed separately)
application-prod.properties
application-production.properties

# Custom environment configs
config/local/
config/dev/
config/development/

# =============================================================================
# Backup Files
# =============================================================================
*.bak
*.backup
*.old
*~
*.orig
*.save

# =============================================================================
# Documentation Generated Files
# =============================================================================
# JavaDoc
/doc/
/javadoc/

# Markdown generated
*.html

# =============================================================================
# Monitoring & Profiling
# =============================================================================
# JProfiler
*.jfr

# Flight Recorder
*.hprof

# Performance monitoring
*.perf
profiler/

# =============================================================================
# OAuth2 & Security Specific
# =============================================================================
# Token storage (if any)
tokens/
.tokens/

# Session storage
sessions/
.sessions/

# Client registration files (if dynamic)
clients/
registered-clients/

# JWKS cache
jwks-cache/
.jwks/

# =============================================================================
# Custom Application Files
# =============================================================================
# Upload directories
uploads/
files/
storage/

# Cache directories
cache/
.cache/

# Runtime generated files
runtime/
work/

# =============================================================================
# CI/CD
# =============================================================================
# GitHub Actions (keep workflows, ignore logs)
.github/workflows/*.log

# Jenkins
.jenkins/

# GitLab CI
.gitlab-ci-local/

# CircleCI
.circleci/local/

# =============================================================================
# Miscellaneous
# =============================================================================
# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# SublimeText
*.sublime-workspace
*.sublime-project

# JetBrains Rider
.idea/
*.sln.iml

# =============================================================================
# Project Specific Exclusions
# =============================================================================
# OAuth2 server specific temporary files
oauth2-temp/
auth-cache/

# Test client applications
test-client/
demo-client/

# Local Postman collections with secrets
*-local.postman_collection.json
*-secrets.postman_environment.json

# =============================================================================
# Include Important Files (Override some ignores)
# =============================================================================
# Ensure these are NOT ignored
!.gitkeep
!.gitignore
!README.md
!LICENSE
!CHANGELOG.md
!src/
!pom.xml

# Include sample/template configuration files
!application.properties.template
!application.properties.example
!docker-compose.yml.template

# Include documentation
!docs/
!*.md