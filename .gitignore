oauth2-server.log*
authorization-server.log*
access.log*
error.log*

# =============================================================================
# Build & Deployment
# =============================================================================
build/
dist/
out/
generated/
generated-sources/
generated-resources/

# Docker
.dockerignore
Dockerfile.local
docker-compose-local.yml
.docker/

# Kubernetes
k8s-local/
*.local.yaml
*.local.yml

# =============================================================================
