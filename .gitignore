# =============================================================================
# Java OAuth2 Authorization Server - .gitignore
# =============================================================================

# =============================================================================
# Java & JVM
# =============================================================================
*.class
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Virtual machine crash logs
hs_err_pid*
replay_pid*

# =============================================================================
